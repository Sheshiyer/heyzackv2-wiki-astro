---

<svg 
  class:list={['hz-icon', className]}
  width={size}
  height={size}
  viewBox="0 0 24 24" 
  fill="none" 
  stroke="currentColor" 
  stroke-width="1.5"
  aria-hidden="true"
  set:html={icons[name] || icons['package']}
/>

<style>
  .hz-icon {
    display: inline-block;
    vertical-align: middle;
    flex-shrink: 0;
    color: inherit;
    transition: color 150ms ease;
  }
  
  /* Brand gradient variant */
  .hz-icon.gradient {
    stroke: url(#brand-gradient);
  }
  
  /* Accent color variant */
  .hz-icon.accent {
    color: var(--color-accent);
  }
  
  /* Brand blue */
  .hz-icon.brand-blue {
    color: var(--color-brand-blue);
  }
  
  /* Brand pink */
  .hz-icon.brand-pink {
    color: var(--color-brand-pink);
  }
  
  /* Success/Check */
  .hz-icon.success {
    color: #22c55e;
  }
  
  /* Error/X */
  .hz-icon.error {
    color: #ef4444;
  }
  
  /* Warning */
  .hz-icon.warning {
    color: #f59e0b;
  }
</style>
