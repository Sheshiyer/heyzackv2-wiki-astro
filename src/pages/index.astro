---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import GlassCard from '../components/GlassCard.astro';
import Icon from '../components/Icon.astro';
import productCatalog from '../data/product_catalog.json';

const docs = await getCollection('docs');

// Group docs by category
const categories = docs.reduce((acc, doc) => {
  const category = doc.data.category || 'General';
  if (!acc[category]) acc[category] = [];
  acc[category].push(doc);
  return acc;
}, {} as Record<string, typeof docs>);

// Sort categories
const categoryOrder = ['home', 'getting-started', 'product', 'brand', 'audience', 'marketing'];
const sortedCategories = Object.keys(categories).sort((a, b) => {
  const aIndex = categoryOrder.indexOf(a.toLowerCase());
  const bIndex = categoryOrder.indexOf(b.toLowerCase());
  if (aIndex === -1 && bIndex === -1) return a.localeCompare(b);
  if (aIndex === -1) return 1;
  if (bIndex === -1) return -1;
  return aIndex - bIndex;
});

const { brand, visual_identity, product_stats } = productCatalog;
---

<BaseLayout title="Home" description="HeyZack Wiki - AI-Powered Smart Home & Building Automation Documentation">
  <!-- Hero Section -->
  <section class="hero">
    <div class="hero-badge">Single Source of Truth</div>
    <h1 class="hero-title">
      <span class="brand-name">HeyZack</span> Wiki
    </h1>
    <p class="hero-tagline">{brand.tagline}</p>
    <div class="hero-stats">
      <div class="stat-item">
        <span class="stat-value">{product_stats.total_products}</span>
        <span class="stat-label">Products</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item">
        <span class="stat-value">{product_stats.total_categories}</span>
        <span class="stat-label">Categories</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item">
        <span class="stat-value">50/50</span>
        <span class="stat-label">B2B/B2C Split</span>
      </div>
    </div>
  </section>

  <!-- Quick Actions -->
  <section class="quick-actions">
    <a href="/products" class="action-card action-products">
      <span class="action-icon"><Icon name="package" size={28} /></span>
      <span class="action-title">Product Catalog</span>
      <span class="action-desc">{product_stats.total_products} smart devices</span>
    </a>
    <a href="/docs/product/overview" class="action-card action-docs">
      <span class="action-icon"><Icon name="book" size={28} /></span>
      <span class="action-title">Documentation</span>
      <span class="action-desc">Brand & marketing guides</span>
    </a>
    <a href="/docs/audience/primary-persona" class="action-card action-personas">
      <span class="action-icon"><Icon name="users" size={28} /></span>
      <span class="action-title">Personas</span>
      <span class="action-desc">B2B & B2C profiles</span>
    </a>
    <a href="/docs/marketing/ad-creative" class="action-card action-marketing">
      <span class="action-icon"><Icon name="megaphone" size={28} /></span>
      <span class="action-title">Marketing Assets</span>
      <span class="action-desc">Ads, emails, campaigns</span>
    </a>
  </section>

  <!-- Product Categories Preview -->
  <section class="section">
    <div class="section-header">
      <h2>Product Categories</h2>
      <a href="/products" class="view-all">View all products →</a>
    </div>
    <div class="category-preview-grid">
      {Object.entries(product_stats.categories_summary).slice(0, 6).map(([name, count]) => (
        <a href={`/products/${name.toLowerCase().replace(/[^a-z0-9]+/g, '-')}`} class="category-preview-card">
          <span class="category-count">{count}</span>
          <span class="category-name">{name}</span>
        </a>
      ))}
    </div>
  </section>

  <!-- Documentation Grid -->
  <section class="section">
    <div class="section-header">
      <h2>Documentation</h2>
    </div>
    <div class="category-grid">
      {sortedCategories.map(category => {
        const categoryDocs = categories[category].slice(0, 4);
        return (
          <GlassCard variant="light">
            <h3 class="category-title">{category}</h3>
            <ul class="category-links">
              {categoryDocs.map(doc => (
                <li>
                  <a href={`/docs/${doc.slug}`}>{doc.data.title}</a>
                </li>
              ))}
            </ul>
            {categories[category].length > 4 && (
              <p class="category-more">+{categories[category].length - 4} more</p>
            )}
          </GlassCard>
        );
      })}
    </div>
  </section>

  <!-- Brand Identity Footer -->
  <section class="brand-footer">
    <div class="brand-colors">
      <div class="color-swatch" style="background: #243984;" title="Primary Blue #243984"></div>
      <div class="color-swatch" style="background: #E82F89;" title="Primary Pink #E82F89"></div>
      <div class="color-swatch" style="background: #2E2D2C;" title="Black #2E2D2C"></div>
      <div class="color-swatch" style="background: #E9EDEF;" title="Grey #E9EDEF"></div>
    </div>
    <p class="brand-tagline">AI Automation for Residential & Commercial Buildings</p>
  </section>
</BaseLayout>

<style>
  /* Hero */
  .hero {
    text-align: center;
    padding: var(--space-10) 0 var(--space-10);
    max-width: 600px;
    margin: 0 auto;
  }
  
  .hero-badge {
    display: inline-block;
    padding: var(--space-2) var(--space-4);
    background: var(--gradient-brand);
    color: white;
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    border-radius: 9999px;
    margin-bottom: var(--space-4);
  }
  
  .hero-title {
    font-size: clamp(2rem, 8vw, 3.5rem);
    margin-bottom: var(--space-3);
    letter-spacing: -0.03em;
  }
  
  .brand-name {
    background: var(--gradient-brand);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  
  .hero-tagline {
    font-size: clamp(1rem, 3vw, var(--text-xl));
    color: var(--color-text-secondary);
    margin-bottom: var(--space-8);
    line-height: 1.6;
  }
  
  .hero-stats {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: var(--space-6);
    padding: var(--space-5);
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    max-width: 100%;
    margin: 0 auto;
    flex-wrap: wrap;
  }
  
  .stat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    min-width: 80px;
  }
  
  .stat-value {
    font-size: clamp(1.5rem, 4vw, var(--text-3xl));
    font-weight: 700;
    color: var(--color-brand-blue);
  }
  
  [data-theme="dark"] .stat-value {
    color: var(--color-accent);
  }
  
  .stat-label {
    font-size: var(--text-sm);
    color: var(--color-text-tertiary);
  }
  
  .stat-divider {
    width: 1px;
    height: 40px;
    background: var(--color-divider);
    flex-shrink: 0;
  }
  
  /* Quick Actions */
  .quick-actions {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: var(--space-4);
    margin-bottom: var(--space-10);
  }
  
  .action-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: var(--space-5);
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    text-decoration: none;
    text-align: center;
    transition: all 200ms cubic-bezier(0.16, 1, 0.3, 1);
  }
  
  .action-card:hover {
    transform: translateY(-4px);
    border-color: var(--color-brand-pink);
    box-shadow: 0 12px 32px rgba(232, 47, 137, 0.15);
  }
  
  .action-icon {
    font-size: 2rem;
    margin-bottom: var(--space-3);
  }
  
  .action-title {
    font-weight: 600;
    color: var(--color-text-primary);
    margin-bottom: var(--space-1);
  }
  
  .action-desc {
    font-size: var(--text-sm);
    color: var(--color-text-tertiary);
  }
  
  /* Sections */
  .section {
    margin-bottom: var(--space-10);
  }
  
  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-5);
    flex-wrap: wrap;
    gap: var(--space-2);
  }
  
  .section-header h2 {
    margin: 0;
    font-size: clamp(1.25rem, 4vw, var(--text-2xl));
  }
  
  .view-all {
    font-size: var(--text-sm);
    color: var(--color-accent);
    white-space: nowrap;
  }
  
  /* Category Preview Grid */
  .category-preview-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: var(--space-3);
  }
  
  .category-preview-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: var(--space-5);
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    text-decoration: none;
    transition: all 200ms cubic-bezier(0.16, 1, 0.3, 1);
  }
  
  .category-preview-card:hover {
    border-color: var(--color-brand-pink);
    background: linear-gradient(135deg, rgba(36, 57, 132, 0.08) 0%, rgba(232, 47, 137, 0.08) 100%);
    transform: translateY(-2px);
  }
  
  .category-count {
    font-size: clamp(1.5rem, 4vw, var(--text-3xl));
    font-weight: 700;
    background: var(--gradient-brand);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  
  .category-name {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    text-align: center;
  }
  
  /* Documentation Grid */
  .category-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: var(--space-5);
  }
  
  .category-title {
    font-size: var(--text-lg);
    margin: 0 0 var(--space-4);
    text-transform: capitalize;
  }
  
  .category-links {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  
  .category-links li {
    margin-bottom: var(--space-2);
  }
  
  .category-links a {
    color: var(--color-text-secondary);
    font-size: var(--text-sm);
    transition: color 150ms ease;
  }
  
  .category-links a:hover {
    color: var(--color-brand-pink);
  }
  
  .category-more {
    font-size: var(--text-sm);
    color: var(--color-text-tertiary);
    margin-top: var(--space-3);
    margin-bottom: 0;
  }
  
  /* Brand Footer */
  .brand-footer {
    text-align: center;
    padding: var(--space-8) 0;
    border-top: 1px solid var(--color-divider);
    margin-top: var(--space-4);
  }
  
  .brand-colors {
    display: flex;
    justify-content: center;
    gap: var(--space-3);
    margin-bottom: var(--space-4);
  }
  
  .color-swatch {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    border: 2px solid var(--color-bg-primary);
    box-shadow: 0 2px 8px rgba(0,0,0,0.15);
    transition: transform 200ms ease;
  }
  
  .color-swatch:hover {
    transform: scale(1.15);
  }
  
  .brand-tagline {
    color: var(--color-text-tertiary);
    font-size: var(--text-sm);
    margin: 0;
  }
  
  /* Responsive */
  @media (max-width: 768px) {
    .hero {
      padding: var(--space-6) 0 var(--space-8);
    }
    
    .hero-stats {
      gap: var(--space-4);
      padding: var(--space-4);
    }
    
    .stat-divider {
      display: none;
    }
    
    .stat-item {
      flex: 1 1 80px;
    }
  }
  
  @media (max-width: 480px) {
    .hero-badge {
      font-size: 0.65rem;
      padding: var(--space-1) var(--space-3);
    }
    
    .action-card {
      padding: var(--space-4);
    }
    
    .action-icon {
      font-size: 1.5rem;
    }
  }
</style>
