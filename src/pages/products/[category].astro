---
import BaseLayout from '../../layouts/BaseLayout.astro';
import productCatalog from '../../data/product_catalog.json';

export function getStaticPaths() {
  return productCatalog.categories.map((cat: any) => ({
    params: { category: cat.name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '') },
    props: { category: cat },
  }));
}

interface Props {
  category: {
    name: string;
    product_count: number;
    products: Array<{
      name: string;
      sku: string;
      specs: string;
      description: string;
      slug: string;
      keywords: string;
    }>;
  };
}

const { category } = Astro.props;
---

<BaseLayout title={category.name} description={`Browse ${category.product_count} ${category.name} products from HeyZack`}>
  <nav class="breadcrumb">
    <a href="/">Home</a>
    <span>/</span>
    <a href="/products">Products</a>
    <span>/</span>
    <span class="current">{category.name}</span>
  </nav>

  <div class="page-header">
    <h1>{category.name}</h1>
    <p class="page-subtitle">{category.product_count} products</p>
  </div>

  <div class="products-grid">
    {category.products.map((product) => (
      <article class="product-card">
        <div class="product-header">
          <h3 class="product-name">{product.name}</h3>
          <span class="product-sku">{product.sku}</span>
        </div>
        
        <p class="product-description">{product.description.split('\n')[0]}</p>
        
        <div class="product-specs">
          <h4>Specifications</h4>
          <p>{product.specs.slice(0, 200)}{product.specs.length > 200 ? '...' : ''}</p>
        </div>
        
        <div class="product-keywords">
          {product.keywords.split(', ').slice(0, 5).map((keyword: string) => (
            <span class="keyword-tag">{keyword}</span>
          ))}
        </div>
      </article>
    ))}
  </div>
</BaseLayout>

<style>
  .breadcrumb {
    display: flex;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-text-tertiary);
    margin-bottom: var(--space-6);
  }
  
  .breadcrumb a {
    color: var(--color-text-secondary);
  }
  
  .breadcrumb a:hover {
    color: var(--color-accent);
  }
  
  .breadcrumb .current {
    color: var(--color-text-primary);
  }
  
  .page-header {
    margin-bottom: var(--space-8);
  }
  
  .page-header h1 {
    margin-bottom: var(--space-2);
    background: var(--gradient-brand);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  
  .page-subtitle {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    margin: 0;
  }
  
  .products-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(380px, 1fr));
    gap: var(--space-6);
  }
  
  .product-card {
    padding: var(--space-6);
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    transition: all 200ms ease;
  }
  
  .product-card:hover {
    border-color: var(--color-brand-pink);
    box-shadow: 0 8px 24px rgba(232, 47, 137, 0.1);
  }
  
  .product-header {
    margin-bottom: var(--space-4);
  }
  
  .product-name {
    font-size: var(--text-lg);
    margin: 0 0 var(--space-1);
    color: var(--color-text-primary);
  }
  
  .product-sku {
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    color: var(--color-text-tertiary);
    background: var(--color-bg-tertiary);
    padding: 2px 6px;
    border-radius: 4px;
  }
  
  .product-description {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin-bottom: var(--space-4);
  }
  
  .product-specs {
    margin-bottom: var(--space-4);
    padding: var(--space-3);
    background: var(--color-bg-tertiary);
    border-radius: var(--radius-sm);
  }
  
  .product-specs h4 {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-tertiary);
    margin: 0 0 var(--space-2);
  }
  
  .product-specs p {
    font-size: var(--text-xs);
    color: var(--color-text-secondary);
    margin: 0;
    line-height: 1.5;
  }
  
  .product-keywords {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-1);
  }
  
  .keyword-tag {
    font-size: var(--text-xs);
    color: var(--color-accent);
    background: rgba(36, 57, 132, 0.1);
    padding: 2px 8px;
    border-radius: 9999px;
  }
  
  [data-theme="dark"] .keyword-tag {
    background: rgba(74, 111, 217, 0.15);
  }
  
  @media (max-width: 768px) {
    .products-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
