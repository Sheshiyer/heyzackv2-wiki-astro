---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GlassCard from '../../components/GlassCard.astro';
import Icon from '../../components/Icon.astro';
import productCatalog from '../../data/product_catalog.json';

const { brand, product_stats, categories } = productCatalog;

// Category icons mapping - using Icon component names
const categoryIcons: Record<string, string> = {
  'Camera and Doorbell': 'camera',
  'Smart Sensors': 'sensor',
  'Smart Control Panel': 'panel',
  'Smart Switch': 'switch',
  'Smart DIY Breaker': 'bolt',
  'Smart Climatisation': 'climate',
  'Smart Music Control System': 'music',
  'Smart Door Lock': 'lock',
  'Smart Door Lock Body': 'door',
  'Smart Circuit Breaker': 'plug',
  'Smart Gateway': 'gateway',
  'Curtain, Shutter and Garage Door Controllers': 'curtain',
  'Smart lighting System and Dimming Controller': 'light',
  'Smart Accessorries': 'wrench',
  'Pet Accesories': 'pet',
};

function slugify(text: string): string {
  return text.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
}
---

<BaseLayout title="Product Catalog" description="Browse all HeyZack smart home products across 15 categories">
  <div class="page-header">
    <h1>Product Catalog</h1>
    <p class="page-subtitle">{product_stats.total_products} smart devices across {product_stats.total_categories} categories</p>
  </div>

  <!-- Stats Bar -->
  <div class="stats-bar">
    <div class="stat">
      <span class="stat-number">{product_stats.total_products}</span>
      <span class="stat-label">Total Products</span>
    </div>
    <div class="stat">
      <span class="stat-number">{product_stats.total_categories}</span>
      <span class="stat-label">Categories</span>
    </div>
    <div class="stat">
      <span class="stat-number">50/50</span>
      <span class="stat-label">B2B/B2C</span>
    </div>
  </div>

  <!-- Categories Grid -->
  <div class="categories-grid">
    {categories.map((category) => (
      <a href={`/products/${slugify(category.name)}`} class="category-card">
        <div class="category-icon"><Icon name={categoryIcons[category.name] || 'package'} size={32} /></div>
        <div class="category-info">
          <h3 class="category-name">{category.name}</h3>
          <span class="category-count">{category.product_count} products</span>
        </div>
        <div class="category-preview">
          {category.products.slice(0, 3).map((product) => (
            <span class="preview-item">{product.name.slice(0, 30)}...</span>
          ))}
        </div>
        <span class="category-arrow">→</span>
      </a>
    ))}
  </div>
</BaseLayout>

<style>
  .page-header {
    margin-bottom: var(--space-8);
  }
  
  .page-header h1 {
    margin-bottom: var(--space-2);
    background: var(--gradient-brand);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  
  .page-subtitle {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    margin: 0;
  }
  
  .stats-bar {
    display: flex;
    gap: var(--space-8);
    padding: var(--space-6);
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    margin-bottom: var(--space-10);
  }
  
  .stat {
    display: flex;
    flex-direction: column;
  }
  
  .stat-number {
    font-size: var(--text-2xl);
    font-weight: 700;
    background: var(--gradient-brand);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  
  .stat-label {
    font-size: var(--text-sm);
    color: var(--color-text-tertiary);
  }
  
  .categories-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
    gap: var(--space-4);
  }
  
  .category-card {
    display: grid;
    grid-template-columns: auto 1fr auto;
    grid-template-rows: auto auto;
    gap: var(--space-2) var(--space-4);
    padding: var(--space-5);
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    text-decoration: none;
    transition: all 200ms ease;
  }
  
  .category-card:hover {
    border-color: var(--color-brand-pink);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(232, 47, 137, 0.1);
  }
  
  .category-icon {
    grid-row: span 2;
    font-size: 2.5rem;
    display: flex;
    align-items: center;
  }
  
  .category-info {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  
  .category-name {
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-text-primary);
    margin: 0;
    line-height: 1.3;
  }
  
  .category-count {
    font-size: var(--text-sm);
    color: var(--color-accent);
  }
  
  .category-preview {
    grid-column: 2;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-1);
  }
  
  .preview-item {
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
    background: var(--color-bg-tertiary);
    padding: 2px 6px;
    border-radius: 4px;
  }
  
  .category-arrow {
    grid-row: span 2;
    display: flex;
    align-items: center;
    font-size: var(--text-xl);
    color: var(--color-text-tertiary);
    transition: transform 200ms ease;
  }
  
  .category-card:hover .category-arrow {
    transform: translateX(4px);
    color: var(--color-brand-pink);
  }
  
  @media (max-width: 768px) {
    .stats-bar {
      flex-wrap: wrap;
      gap: var(--space-4);
    }
    
    .categories-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
